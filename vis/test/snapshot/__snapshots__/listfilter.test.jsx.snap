// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`List filter component snapshot > matches a snapshot 1`] = `
<div
  className="row"
  id="explorer_options"
  style={
    {
      "borderBottom": "",
    }
  }
>
  <div
    id="filter_container"
  >
    <div
      className="input-group input-group-sm"
    >
      <i
        className="fa fa-search searchfield-icon"
      />
      <input
        className="form-control"
        id="filter_input"
        onChange={[Function]}
        placeholder="Search..."
        type="text"
        value="case study"
      />
      <span
        className="glyphicon glyphicon-remove-circle"
        id="searchclear"
        onClick={[Function]}
      />
    </div>
  </div>
  <div>
    <div
      className="dropdown"
      id="filter_parameter_container"
    >
      <div
        className="dropdown btn-group"
      >
        <button
          aria-expanded={false}
          aria-haspopup={true}
          className="truncate-text dropdown-toggle btn btn-default"
          disabled={false}
          id="filter_params"
          onClick={[Function]}
          onKeyDown={[Function]}
          role="button"
          type="button"
        >
          <span
            style={
              {
                "alignItems": "center",
                "display": "flex",
                "justifyContent": "center",
                "maxWidth": "100%",
              }
            }
          >
            <span>
              Filter by: 
            </span>
            <span
              className="truncate-text"
              id="curr-filter-type"
              style={
                {
                  "marginLeft": "3px",
                  "minWidth": "0px",
                }
              }
            >
              All
            </span>
            <i
              className="fas fa-chevron-down chevron"
              style={
                {
                  "marginLeft": "3px",
                }
              }
            />
          </span>
        </button>
        <ul
          aria-labelledby="filter_params"
          className="dropdown-menu"
          role="menu"
        >
          <li
            className="active"
            role="presentation"
          >
            <a
              href="#"
              id="filter_option_all"
              onClick={[Function]}
              onKeyDown={[Function]}
              role="menuitem"
              tabIndex="-1"
            >
              <div
                className="wrap"
              >
                All
              </div>
            </a>
          </li>
          <li
            className=""
            role="presentation"
          >
            <a
              href="#"
              id="filter_option_open_access"
              onClick={[Function]}
              onKeyDown={[Function]}
              role="menuitem"
              tabIndex="-1"
            >
              <div
                className="wrap"
              >
                Open access
              </div>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
`;
